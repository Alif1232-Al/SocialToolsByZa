# === AUTHENTICATION ===
# Email & password admin untuk login
ADMIN_EMAIL=
ADMIN_PASSWORD=

# JWT secret — generate pake: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# === SUPABASE (opsional) — kalo dikosongin, pake JSON file ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === API KEYS ===
# SerpAPI — https://serpapi.com (buat Jurnal Finder & Dorking)
SERPAPI_API_KEY=

# Remove.bg — https://remove.bg (buat Remove Background, gratis 50 foto/bulan)
REMOVEBG_API_KEY=

# === TRIPAY (otomatis premium) ===
# Daftar gratis di https://tripay.co.id
# Dapetin API Key, Private Key, sama Merchant Code dari dashboard
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
